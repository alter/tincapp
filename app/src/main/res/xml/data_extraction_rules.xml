<data-extraction-rules xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="FullBackupContent">

    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <include
            domain="file"
            path="./" />
        <include
            domain="external"
            path="./" />
        <!-- Private tinc keys never leave the device via cloud backup. -->
        <exclude domain="file" path="networks/" />
        <exclude domain="external" path="networks/" />
    </cloud-backup>

    <device-transfer>
        <include
            domain="file"
            path="./" />
        <include
            domain="external"
            path="./" />
        <!-- Same protection during device-to-device transfer. -->
        <exclude domain="file" path="networks/" />
        <exclude domain="external" path="networks/" />
    </device-transfer>

</data-extraction-rules>
