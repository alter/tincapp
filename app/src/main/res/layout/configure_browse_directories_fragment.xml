<layout xmlns:android="http://schemas.android.com/apk/res/android">

	<data>

		<import
			type="org.pacien.tincapp.storageprovider.FilesDocumentsProvider"/>

		<variable
			name="openDirectoryTree"
			type="kotlin.jvm.functions.Function1&lt;String, kotlin.Unit>"/>

	</data>

	<LinearLayout style="@style/AppTheme.List">

		<LinearLayout
			style="@style/AppTheme.ListBlock.Clickable"
			android:onClick="@{() -> openDirectoryTree.invoke(FilesDocumentsProvider.VIRTUAL_ROOT_NETWORKS)}">

			<TextView
				style="@style/AppTheme.BlockTitle"
				android:text="@string/configure_browse_directories_action_open_networks_config" />

		</LinearLayout>

		<LinearLayout
			style="@style/AppTheme.ListBlock.Clickable"
			android:onClick="@{() -> openDirectoryTree.invoke(FilesDocumentsProvider.VIRTUAL_ROOT_LOGS)}">

			<TextView
				style="@style/AppTheme.BlockTitle"
				android:text="@string/configure_browse_directories_action_open_logs" />

		</LinearLayout>

	</LinearLayout>

</layout>
